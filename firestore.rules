rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function authEmail() {
      return request.auth.token.email;
    }

    function isAdminEmail() {
      return authEmail() == "joseph.clark@doralacademynv.org";
    }

    function isStudentEmail() {
      return authEmail().matches(".*@student[.]doralacademynv[.]org$");
    }

    function isTeacherEmail() {
      return authEmail().matches(".*@doralacademynv[.]org$") && !isAdminEmail();
    }

    function isAllowedEmail() {
      return isAdminEmail() || isStudentEmail() || isTeacherEmail();
    }

    function userProfilePath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function signedInProfile() {
      return get(userProfilePath(request.auth.uid));
    }

    function hasProfile() {
      return isSignedIn() && exists(userProfilePath(request.auth.uid));
    }

    function userRole() {
      return signedInProfile().data.role;
    }

    function userSchoolId() {
      return signedInProfile().data.schoolId;
    }

    function isAdminProfile() {
      return hasProfile() && userRole() == "admin";
    }

    function isTeacherProfile() {
      return hasProfile() && userRole() == "teacher";
    }

    function isStudentProfile() {
      return hasProfile() && userRole() == "student";
    }

    function isSchoolMember(schoolId) {
      return hasProfile() && userSchoolId() == schoolId;
    }

    function sectionPath(schoolId, sectionId) {
      return /databases/$(database)/documents/schools/$(schoolId)/sections/$(sectionId);
    }

    function sectionExists(schoolId, sectionId) {
      return exists(sectionPath(schoolId, sectionId));
    }

    function sectionData(schoolId, sectionId) {
      return get(sectionPath(schoolId, sectionId)).data;
    }

    function isSectionTeacher(schoolId, sectionId) {
      return sectionExists(schoolId, sectionId)
        && sectionData(schoolId, sectionId).teacherUid == request.auth.uid;
    }

    function isSectionAdmin(schoolId) {
      return isAdminProfile() && isSchoolMember(schoolId);
    }

    function userSectionPath(uid, sectionId) {
      return /databases/$(database)/documents/users/$(uid)/sections/$(sectionId);
    }

    function isEnrolledInSection(schoolId, sectionId) {
      return isStudentProfile()
        && exists(userSectionPath(request.auth.uid, sectionId))
        && get(userSectionPath(request.auth.uid, sectionId)).data.schoolId == schoolId
        && get(userSectionPath(request.auth.uid, sectionId)).data.status == "active";
    }

    function roleMatchesEmail() {
      return (
        request.resource.data.role == "admin" && isAdminEmail()
      ) || (
        request.resource.data.role == "student" && isStudentEmail()
      ) || (
        request.resource.data.role == "teacher" && isTeacherEmail()
      );
    }

    function userDocumentShapeIsAllowed() {
      return request.resource.data.keys().hasOnly([
        "uid",
        "email",
        "displayName",
        "role",
        "schoolId",
        "schoolName",
        "schoolCodeUsed",
        "createdAt",
        "lastLogin"
      ]);
    }

    function curriculumFieldsAreValid() {
      return request.resource.data.curriculumId is string
        && request.resource.data.curriculumTitle is string
        && request.resource.data.curriculumSubject is string;
    }

    function sectionCreateShapeIsAllowed(schoolId) {
      return request.resource.data.keys().hasOnly([
        "sectionId",
        "schoolId",
        "teacherUid",
        "teacherName",
        "teacherEmail",
        "courseName",
        "period",
        "sectionName",
        "classCode",
        "classCodeUpper",
        "active",
        "createdAt",
        "updatedAt",
        "studentCount",
        "studentUids",
        "curriculumId",
        "curriculumTitle",
        "curriculumSubject"
      ])
      && request.resource.data.schoolId == schoolId
      && request.resource.data.teacherUid == request.auth.uid
      && request.resource.data.active == true
      && request.resource.data.studentCount == 0
      && request.resource.data.studentUids == []
      && curriculumFieldsAreValid();
    }

    function studentJoinSectionUpdateIsAllowed(schoolId, sectionId) {
      return isStudentProfile()
        && isSchoolMember(schoolId)
        && resource.data.active == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "studentCount",
          "studentUids",
          "updatedAt"
        ])
        && request.auth.uid in request.resource.data.studentUids
        && existsAfter(
          /databases/$(database)/documents/schools/$(schoolId)/sections/$(sectionId)/enrollments/$(request.auth.uid)
        )
        && existsAfter(
          /databases/$(database)/documents/users/$(request.auth.uid)/sections/$(sectionId)
        );
    }

    function teacherSectionUpdateIsAllowed(schoolId, sectionId) {
      return isSchoolMember(schoolId)
        && (isSectionAdmin(schoolId) || isSectionTeacher(schoolId, sectionId));
    }

    function teacherSectionWriteIsAllowed(schoolId, sectionId) {
      return isSignedIn()
        && isSchoolMember(schoolId)
        && (isSectionAdmin(schoolId) || isSectionTeacher(schoolId, sectionId));
    }

    function assignmentSubmissionFieldsAreAllowed() {
      return request.resource.data.keys().hasOnly([
        "assignmentId",
        "assignmentTitle",
        "sectionId",
        "schoolId",
        "studentUid",
        "studentName",
        "studentEmail",
        "answers",
        "correctCount",
        "score",
        "problemCount",
        "percent",
        "gradePercent",
        "status",
        "attemptNumber",
        "maxAttempts",
        "attempts",
        "feedback",
        "resubmissionAllowed",
        "resubmissionDueDate",
        "isDemo",
        "submittedAt",
        "updatedAt",
        "gradedAt",
        "reviewedByEmail",
        "reviewedByUid"
      ]);
    }

    function submissionReviewFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "feedback",
        "gradedAt",
        "maxAttempts",
        "resubmissionAllowed",
        "resubmissionDueDate",
        "reviewedByEmail",
        "reviewedByUid",
        "status",
        "updatedAt"
      ]);
    }

    function demoSubmissionFieldsAreAllowed() {
      return request.resource.data.keys().hasOnly([
        "assignmentId",
        "assignmentTitle",
        "sectionId",
        "schoolId",
        "demoStudentId",
        "demoStudentName",
        "demoStudentEmail",
        "isDemo",
        "submittedByTeacherUid",
        "submittedByTeacherEmail",
        "answers",
        "correctCount",
        "score",
        "problemCount",
        "percent",
        "gradePercent",
        "status",
        "attemptNumber",
        "maxAttempts",
        "attempts",
        "feedback",
        "resubmissionAllowed",
        "resubmissionDueDate",
        "submittedAt",
        "updatedAt",
        "gradedAt",
        "reviewedByEmail",
        "reviewedByUid"
      ]);
    }

    function progressFieldsAreAllowed() {
      return request.resource.data.keys().hasOnly([
        "schoolId",
        "sectionId",
        "assignmentId",
        "studentUid",
        "demoStudentId",
        "studentName",
        "studentEmail",
        "isDemo",
        "status",
        "answeredCount",
        "totalProblems",
        "progressPercent",
        "lastActivityAt",
        "openedAt",
        "submittedAt",
        "attemptNumber",
        "score",
        "gradePercent",
        "resubmissionAllowed",
        "needsResubmission",
        "submittedByTeacherUid",
        "submittedByTeacherEmail",
        "updatedAt"
      ]);
    }

    function studentProgressStatusIsAllowed() {
      return request.resource.data.status in [
        "started",
        "working",
        "nearly_done",
        "submitted",
        "resubmitted"
      ];
    }

    function teacherProgressStatusIsAllowed() {
      return request.resource.data.status in [
        "started",
        "working",
        "nearly_done",
        "submitted",
        "resubmitted",
        "graded",
        "needs_resubmission"
      ];
    }

    function studentProgressWriteIsAllowed(schoolId, sectionId, assignmentId, studentKey) {
      return isSignedIn()
        && request.auth.uid == studentKey
        && isEnrolledInSection(schoolId, sectionId)
        && request.resource.data.schoolId == schoolId
        && request.resource.data.sectionId == sectionId
        && request.resource.data.assignmentId == assignmentId
        && request.resource.data.studentUid == request.auth.uid
        && request.resource.data.isDemo == false
        && studentProgressStatusIsAllowed()
        && progressFieldsAreAllowed();
    }

    function teacherProgressWriteIsAllowed(schoolId, sectionId, assignmentId, studentKey) {
      return teacherSectionWriteIsAllowed(schoolId, sectionId)
        && request.resource.data.schoolId == schoolId
        && request.resource.data.sectionId == sectionId
        && request.resource.data.assignmentId == assignmentId
        && teacherProgressStatusIsAllowed()
        && progressFieldsAreAllowed()
        && (
          (
            request.resource.data.isDemo == true
            && request.resource.data.demoStudentId == studentKey
            && request.resource.data.submittedByTeacherUid == request.auth.uid
          )
          || (
            request.resource.data.isDemo == false
            && request.resource.data.studentUid == studentKey
          )
        );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;

      allow create, update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == authEmail()
        && isAllowedEmail()
        && roleMatchesEmail()
        && userDocumentShapeIsAllowed();

      allow delete: if false;

      match /sections/{sectionId} {
        allow read: if isSignedIn() && request.auth.uid == userId;

        allow create, update: if isSignedIn()
          && request.auth.uid == userId
          && hasProfile()
          && request.resource.data.schoolId == userSchoolId()
          && request.resource.data.sectionId == sectionId;

        allow delete: if isSignedIn()
          && resource.data.schoolId == userSchoolId()
          && (
            request.auth.uid == userId
            || isSectionAdmin(resource.data.schoolId)
            || isSectionTeacher(resource.data.schoolId, sectionId)
          );
      }
    }

    match /schools/{schoolId} {
      allow read: if isSignedIn()
        && isAllowedEmail()
        && resource.data.active == true;

      allow write: if false;

      match /curriculumPackages/{curriculumId} {
        allow read: if isSignedIn()
          && isSchoolMember(schoolId)
          && resource.data.active == true;

        allow create, update, delete: if isSectionAdmin(schoolId);
      }

      match /classCodes/{classCode} {
        allow get: if isSignedIn() && isSchoolMember(schoolId);

        allow list: if false;

        allow create: if isSignedIn()
          && isSchoolMember(schoolId)
          && (isTeacherProfile() || isAdminProfile())
          && request.resource.data.schoolId == schoolId
          && request.resource.data.teacherUid == request.auth.uid
          && request.resource.data.active == true
          && existsAfter(sectionPath(schoolId, request.resource.data.sectionId));

        allow update, delete: if isSignedIn()
          && isSchoolMember(schoolId)
          && (
            isSectionAdmin(schoolId)
            || isSectionTeacher(schoolId, resource.data.sectionId)
          );
      }

      match /sections/{sectionId} {
        allow read: if isSignedIn()
          && isSchoolMember(schoolId)
          && resource.data.active == true;

        allow create: if isSignedIn()
          && isSchoolMember(schoolId)
          && (isTeacherProfile() || isAdminProfile())
          && sectionCreateShapeIsAllowed(schoolId);

        allow update: if studentJoinSectionUpdateIsAllowed(schoolId, sectionId)
          || teacherSectionUpdateIsAllowed(schoolId, sectionId);

        allow delete: if false;

        match /assignments/{assignmentId} {
          allow read: if isSignedIn()
            && isSchoolMember(schoolId)
            && resource.data.active == true
            && (
              isSectionAdmin(schoolId)
              || isSectionTeacher(schoolId, sectionId)
              || isEnrolledInSection(schoolId, sectionId)
            );

          allow create: if teacherSectionWriteIsAllowed(schoolId, sectionId)
            && request.resource.data.schoolId == schoolId
            && request.resource.data.sectionId == sectionId
            && request.resource.data.assignmentId == assignmentId
            && request.resource.data.teacherUid == request.auth.uid
            && request.resource.data.active == true
            && request.resource.data.keys().hasOnly([
              "assignmentId",
              "schoolId",
              "sectionId",
              "sectionName",
              "course",
              "courseName",
              "period",
              "subject",
              "curriculumId",
              "curriculumTitle",
              "curriculumSubject",
              "assignmentType",
              "title",
              "directions",
              "problemCount",
              "dueDate",
              "feedbackMode",
              "maxAttempts",
              "timeLimitMinutes",
              "active",
              "teacherUid",
              "teacherName",
              "teacherEmail",
              "createdAt",
              "updatedAt"
            ]);

          allow update, delete: if teacherSectionWriteIsAllowed(schoolId, sectionId);

          match /submissions/{studentUid} {
            allow read: if isSignedIn()
              && isSchoolMember(schoolId)
              && (
                request.auth.uid == studentUid
                || isSectionAdmin(schoolId)
                || isSectionTeacher(schoolId, sectionId)
              );

            allow create: if isSignedIn()
              && request.auth.uid == studentUid
              && isEnrolledInSection(schoolId, sectionId)
              && request.resource.data.studentUid == request.auth.uid
              && request.resource.data.schoolId == schoolId
              && request.resource.data.sectionId == sectionId
              && request.resource.data.assignmentId == assignmentId
              && request.resource.data.isDemo == false
              && assignmentSubmissionFieldsAreAllowed();

            allow update: if (
              isSignedIn()
              && request.auth.uid == studentUid
              && isEnrolledInSection(schoolId, sectionId)
              && request.resource.data.studentUid == request.auth.uid
              && request.resource.data.schoolId == schoolId
              && request.resource.data.sectionId == sectionId
              && request.resource.data.assignmentId == assignmentId
              && request.resource.data.isDemo == false
              && assignmentSubmissionFieldsAreAllowed()
            ) || (
              teacherSectionWriteIsAllowed(schoolId, sectionId)
              && resource.data.studentUid == studentUid
              && submissionReviewFieldsOnly()
            );

            allow delete: if teacherSectionWriteIsAllowed(schoolId, sectionId);
          }

          match /demoSubmissions/{demoStudentId} {
            allow read: if teacherSectionWriteIsAllowed(schoolId, sectionId);

            allow create: if teacherSectionWriteIsAllowed(schoolId, sectionId)
              && request.resource.data.schoolId == schoolId
              && request.resource.data.sectionId == sectionId
              && request.resource.data.assignmentId == assignmentId
              && request.resource.data.demoStudentId == demoStudentId
              && request.resource.data.isDemo == true
              && request.resource.data.submittedByTeacherUid == request.auth.uid
              && demoSubmissionFieldsAreAllowed();

            allow update: if teacherSectionWriteIsAllowed(schoolId, sectionId)
              && request.resource.data.schoolId == schoolId
              && request.resource.data.sectionId == sectionId
              && request.resource.data.assignmentId == assignmentId
              && request.resource.data.demoStudentId == demoStudentId
              && request.resource.data.isDemo == true
              && demoSubmissionFieldsAreAllowed();

            allow delete: if teacherSectionWriteIsAllowed(schoolId, sectionId);
          }

          match /progress/{studentKey} {
            allow get: if teacherSectionWriteIsAllowed(schoolId, sectionId)
              || (
                isSignedIn()
                && request.auth.uid == studentKey
                && isEnrolledInSection(schoolId, sectionId)
              );

            allow list: if teacherSectionWriteIsAllowed(schoolId, sectionId);

            allow create, update: if studentProgressWriteIsAllowed(
              schoolId,
              sectionId,
              assignmentId,
              studentKey
            ) || teacherProgressWriteIsAllowed(
              schoolId,
              sectionId,
              assignmentId,
              studentKey
            );

            allow delete: if teacherSectionWriteIsAllowed(schoolId, sectionId);
          }
        }

        match /demoStudents/{demoStudentId} {
          allow read: if teacherSectionWriteIsAllowed(schoolId, sectionId);

          allow create, update: if teacherSectionWriteIsAllowed(schoolId, sectionId)
            && request.resource.data.demoStudentId == demoStudentId
            && request.resource.data.schoolId == schoolId
            && request.resource.data.sectionId == sectionId
            && request.resource.data.isDemo == true
            && request.resource.data.status == "active"
            && request.resource.data.createdByUid == request.auth.uid
            && request.resource.data.keys().hasOnly([
              "demoStudentId",
              "firstName",
              "lastName",
              "displayName",
              "email",
              "schoolId",
              "sectionId",
              "status",
              "isDemo",
              "createdAt",
              "createdByUid",
              "updatedAt"
            ]);

          allow delete: if teacherSectionWriteIsAllowed(schoolId, sectionId);
        }

        match /enrollments/{studentUid} {
          allow read: if isSignedIn()
            && isSchoolMember(schoolId)
            && (
              request.auth.uid == studentUid
              || isSectionAdmin(schoolId)
              || isSectionTeacher(schoolId, sectionId)
            );

          allow create: if isSignedIn()
            && isStudentProfile()
            && isSchoolMember(schoolId)
            && request.auth.uid == studentUid
            && request.resource.data.studentUid == request.auth.uid
            && request.resource.data.status == "active"
            && sectionExists(schoolId, sectionId)
            && sectionData(schoolId, sectionId).active == true
            && existsAfter(
              /databases/$(database)/documents/users/$(request.auth.uid)/sections/$(sectionId)
            );

          allow update: if false;

          allow delete: if isSignedIn()
            && isSchoolMember(schoolId)
            && (
              request.auth.uid == studentUid
              || isSectionAdmin(schoolId)
              || isSectionTeacher(schoolId, sectionId)
            );
        }
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
